# ╔══════════════════════════════════════════════╗
# ║           CutWise IMS — .gitignore           ║
# ╚══════════════════════════════════════════════╝

# ──────────────────────────────────────────────
# Environment & Secrets
# ──────────────────────────────────────────────
.env
.env.local
.env.*.local

# ──────────────────────────────────────────────
# Python / Django
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
*.sqlite3
db.sqlite3
staticfiles/
media/
*.log

# ──────────────────────────────────────────────
# Node / React (Vite)
# ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
frontend/dist/
frontend/build/
*.tsbuildinfo

# ──────────────────────────────────────────────
# IDE & Editor
# ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────
# Testing & Coverage
# ──────────────────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
nosetests.xml

# ──────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
